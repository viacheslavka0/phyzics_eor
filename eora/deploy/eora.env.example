# Скопируйте на сервер как /etc/eora.env и выставьте chmod 600.
# Подставьте свои значения; строки с # в начале — комментарии.

DJANGO_SETTINGS_MODULE=eora.settings

# Обязательно в проде (сгенерируйте: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=замените_на_случайную_строку

DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=demo.example.com,www.demo.example.com

# HTTPS + сессии/CSRF (домены со схемой, через запятую)
DJANGO_CSRF_TRUSTED_ORIGINS=https://demo.example.com,https://www.demo.example.com

# Если фронт и API на одном домене — можно не задавать. Иначе: https://app.example.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://demo.example.com

# PostgreSQL (локально на VPS чаще всего 127.0.0.1). Спецсимволы в пароле — URL-encode в строке.
DATABASE_URL=postgres://eora_user:ПАРОЛЬ@127.0.0.1:5432/eora_db

# Опционально: если за Nginx нет HTTPS и тестируете с DEBUG=False — поставьте 0
# DJANGO_SESSION_COOKIE_SECURE=0
# DJANGO_CSRF_COOKIE_SECURE=0

# Редирект HTTP→HTTPS лучше делать в Nginx; Django-редирект по умолчанию выключен
# DJANGO_SECURE_SSL_REDIRECT=1
